        "start_offset": 145,
        "end_offset": 312,
        "start": 9.541,
        "end": 28.402
      },
      {
        "segment": "I am Ra.",
        "start_offset": 313,
        "end_offset": 321,
        "start": 28.422,
        "end": 28.562
      },
      {
        "segment": "Each entity is responsible for itself.",
