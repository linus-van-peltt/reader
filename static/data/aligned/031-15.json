        "end_offset": 341,
        "start": 44.502,
        "end": 45.642
      },
      {
        "segment": "The cause of this is not Orion.",
        "start_offset": 342,
        "end_offset": 373,
        "start": 47.682,
        "end": 53.842
      },
      {
        "segment": "It is the free choice of your peoples.",
        "start_offset": 374,
