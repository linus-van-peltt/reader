        "end_offset": 970,
        "start": 233.785,
        "end": 263.205
      },
      {
        "segment": "That which is not may be seen as a self-imposed darkness in which harmony is turned into an eternal disharmony.",
        "start_offset": 971,
        "end_offset": 1082,
        "start": 269.765,
        "end": 297.786
      },
      {
