        "start": 75.421,
        "end": 75.561
      },
      {
        "segment": "I am, with the social memory complex of which I am a part, one of those who voyaged outward from another planet within your own solar system, as this entity would call it.",
        "start_offset": 346,
        "end_offset": 517,
        "start": 77.421,
        "end": 130.722
