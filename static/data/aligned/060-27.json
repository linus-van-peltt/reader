        "start": 180.43,
        "end": 201.991
      },
      {
        "segment": "We believe the Orion group has precisely the same difficulty.",
        "start_offset": 783,
        "end_offset": 844,
        "start": 204.391,
        "end": 218.452
      },
      {
        "segment": "Once this basic information is received it is not put into practice in the heart and in the life experience but instead rattles about within the mind complex distortions as would a building block which has lost its place and simply rolls from side to side uselessly, yet still the entity calls.",
        "start_offset": 845,
        "end_offset": 1139,
        "start": 220.732,
        "end": 289.936
      },
      {
