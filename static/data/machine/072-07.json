        "start": 254.24,
        "end": 269.6
      },
      {
        "segment": "The corresponding polarity will be activated in the circumstance of this group.",
        "start_offset": 3406,
        "end_offset": 3754,
        "start": 272.48,
        "end": 300.32
      },
      {
