        "end_offset": 1036,
        "start": 58.480000000000004,
        "end": 82.88
      },
      {
        "segment": "Therefore, counsel we this instrument to attempt to assess the vital energies carefully before offering itself as open channel.",
        "start_offset": 1052,
        "end_offset": 1372,
        "start": 84.16,
        "end": 109.76
      },
      {
        "segment": "All is well.",
        "start_offset": 1386,
        "end_offset": 1410,
        "start": 110.88,
        "end": 112.8
      },
      {
        "segment": "I leave this instrument and you in the love and in the light of the one infinite creator.",
